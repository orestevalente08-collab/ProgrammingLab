    "import numpy as np\n",
    "def primi(a):\n",
    "    for i in range(2, a-1):\n",
    "        if(a%i == 0):\n",
    "            return False\n",
    "    return True\n",
    "arr = np.array([i for i in range(11) if primi(i)])\n",
    "print(arr)\n"
   ]
